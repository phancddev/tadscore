# Copy to .env and replace every CHANGE_ME value before starting the stack.
COMPOSE_PROJECT_NAME=tadscore
APP_PORT=1107
MAILPIT_UI_PORT=1109
WEB_ORIGIN=http://localhost:1107
RULE_CONFIG_PATH=/app/rule-config

POSTGRES_DB=tadscore
POSTGRES_USER=tadscore
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DATABASE_PASSWORD
DATABASE_URL=postgresql://tadscore:CHANGE_ME_LOCAL_DATABASE_PASSWORD@postgres:5432/tadscore?sslmode=disable

AUTH_EMAIL_VERIFICATION_MODE=otp
AUTH_OTP_LENGTH=6
AUTH_OTP_TTL_SECONDS=86400
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=300
AUTH_OTP_MAX_SENDS=5
AUTH_OTP_SEND_WINDOW_SECONDS=86400
AUTH_OTP_LOCK_SECONDS=18000
SESSION_COOKIE_NAME=tadscore_session
SESSION_TTL_SECONDS=604800
COOKIE_SECURE=false
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCK_SECONDS=900

# Local SMTP capture. No external email service is required.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=TadScore Local <noreply@tadscore.local>

UPLOAD_DIR=/data/uploads
MAX_AVATAR_BYTES=5242880
LOG_LEVEL=info
TRUST_PROXY=true
